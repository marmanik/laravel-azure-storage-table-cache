{
    "name": "marmanik/laravel-azure-table-cache",
    "description": "Azure Storage Table cache driver for Laravel",
    "keywords": [
        "marmanik",
        "laravel",
        "azure",
        "cache",
        "azure-storage",
        "table-storage"
    ],
    "version": "1.0.4",
    "homepage": "https://github.com/marmanik/laravel-azure-table-cache",
    "license": "MIT",
    "authors": [
        {
            "name": "marmanik",
            "email": "marmaridisn@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16",
        "microsoft/azure-storage-table": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Marmanik\\AzureTableCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marmanik\\AzureTableCache\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "./vendor/bin/phpstan analyse",
        "test": "./vendor/bin/pest",
        "test-coverage": "./vendor/bin/pest --coverage",
        "format": "./vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Marmanik\\AzureTableCache\\AzureTableCacheServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
